{
  "manifest_version": 3,
  "name": "Boosty Bookmark",
  "version": "1.0",
  "description": "Помогает следить за выходом озвучек манхвы и маньхуа, а также за прогрессом на Boosty.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://boosty.to/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://boosty.to/*"
      ],
      "js": [
        "page_script.js"
      ],
      "run_at": "document_end",
      "world": "MAIN"
    }
  ]
}