{
  "manifest_version": 3,
  "name": "LightFox Boosty Bookmark",
  "version": "1.0",
  "description": "Помощник для отслеживания озвучек манги и прогресса на Boosty автора LightFox.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://boosty.to/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ]
}
