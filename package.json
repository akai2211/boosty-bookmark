{
  "name": "boosty-bookmark",
  "version": "0.9.0",
  "description": "",
  "type": "module",
  "main": "content.js",
  "scripts": {
    "build:js": "esbuild src/content.js --bundle --define:DEV=true --outfile=content.js --sourcemap",
    "watch:js": "esbuild src/content.js --bundle --define:DEV=true --outfile=content.js --watch --sourcemap",
    "pretest": "npm run build:js",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "build": "node build.cjs",
    "build:firefox": "node build.cjs --firefox"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akai2211/boosty-bookmark.git"
  },
