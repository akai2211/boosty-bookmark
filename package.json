  },
  "homepage": "https://github.com/akai2211/boosty-bookmark#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "archiver": "^8.0.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.8"
  }
}
